# --- Global dotfile ignore ---
# Ignore all dotfiles and dotdirectories by default
.*
.*/

# EXCEPT for essential project and repository configuration
!.gitignore

# --- Lughus Specific ignores ---
key.json
scratch/

# --- Lock files ---
*.lock

# --- Generated demo/test outputs ---
*.pptx
*.xlsx
*.pdf

# --- Python compile & package artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/

# --- Environments & Tooling (fallback for non-dot envs) ---
env/
venv/
